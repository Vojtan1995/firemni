# Lokální PostgreSQL (Windows, bez Dockeru)
# Výchozí role/DB z docs/setup-local-postgres.sql:
#   user: ucpavky
#   password: ucpavky_dev
#   database: ucpavky
#   host/port: localhost:5432
DATABASE_URL=postgresql://ucpavky:ucpavky_dev@localhost:5432/ucpavky

# Backend integrační testy (npm test) – oddělená DB, viz docs/setup-local-postgres-test.sql
# TEST_DATABASE_URL=postgresql://ucpavky:ucpavky_dev@localhost:5432/ucpavky_test

PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
UPLOAD_PATH=./uploads
CORS_ORIGIN=*
ALLOW_WILDCARD_CORS=true
PUBLIC_UPLOADS=true

# ------------------------------------------------------------
# Railway demo/beta (produkční hostované API)
# ------------------------------------------------------------
# Na Railway nastavte proměnné v service Variables:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# NODE_ENV=production
# JWT_SECRET=<vygenerovany_silny_secret>
# CORS_ORIGIN=*  (jen demo), pro produkci nastavte konkrétní originy
# UPLOAD_PATH=./uploads
# ALLOW_WILDCARD_CORS=true
# PUBLIC_UPLOADS=true
#
# Poznámka: uploads na Railway v tomto nastavení nejsou perzistentní
# řešení (demo-only).
