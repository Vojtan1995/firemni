# Lokální PostgreSQL (Windows, bez Dockeru)
# Výchozí role/DB z docs/setup-local-postgres.sql:
#   user: ucpavky
#   password: ucpavky_dev
#   database: ucpavky
#   host/port: localhost:5432
DATABASE_URL=postgresql://ucpavky:ucpavky_dev@localhost:5432/ucpavky

# Backend integrační testy (npm test) – oddělená DB, viz docs/setup-local-postgres-test.sql
# TEST_DATABASE_URL=postgresql://ucpavky:ucpavky_dev@localhost:5432/ucpavky_test

PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
UPLOAD_PATH=./uploads
CORS_ORIGIN=*
ALLOW_WILDCARD_CORS=true
PUBLIC_UPLOADS=true

# Retence logů (GDPR) – ve vývoji vypnuto, v produkci zapnuto automaticky.
# LOG_RETENTION_ENABLED=false
# LOG_RETENTION_DAYS=90
# LOG_RETENTION_INTERVAL_HOURS=24
# MESSAGE_RETENTION_DAYS=365
# NOTIFICATION_RETENTION_DAYS=180

# Admin MFA rollout. Generate MFA_DATA_KEY as 32 random bytes encoded as 64 hex chars.
ADMIN_MFA_REQUIRED=false
# MFA_DATA_KEY=
MFA_ISSUER=UNIFAST Ucpavky
PRIVACY_NOTICE_VERSION=2026-06-27
# PRIVACY_NOTICE_URL=https://intranet.example.com/privacy
# SECURITY_ALERT_TELEGRAM_BOT_TOKEN=
# SECURITY_ALERT_TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Railway demo/beta (produkční hostované API)
# ------------------------------------------------------------
# Na Railway nastavte proměnné v service Variables:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# NODE_ENV=production
# JWT_SECRET=<vygenerovany_silny_secret>
# CORS_ORIGIN=*  (jen demo), pro produkci nastavte konkrétní originy
# ALLOW_WILDCARD_CORS=true
# PUBLIC_UPLOADS=false
# STORAGE_DRIVER=s3
# R2_ACCOUNT_ID=<cloudflare-account-id>  # volitelne lokalne; helper z nej slozi S3_ENDPOINT
# S3_BUCKET=<r2-bucket-name>
# S3_ACCESS_KEY_ID=<r2-access-key-id>
# S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
# S3_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true
# S3_KEY_PREFIX=photos
# VERIFY_STORAGE_ON_START=true
# ADMIN_MFA_REQUIRED=true
# MFA_DATA_KEY=<64_HEX_CHARACTERS>
# MFA_ISSUER=UNIFAST Ucpavky
# BACKUP_REPORT_TOKEN=<same-token-as-github-secret>
# ALLOW_LOCAL_BACKUP_IN_PRODUCTION=false
#
# Poznamka: lokalni UPLOAD_PATH na Railway neni perzistentni.
# Produkce musi pouzivat STORAGE_DRIVER=s3 (R2/S3), viz docs/R2_STORAGE_RUNBOOK.md.
