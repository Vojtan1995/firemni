NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST:5432/STAGING_DB
JWT_SECRET=<STAGING_ONLY_RANDOM_SECRET>
CORS_ORIGIN=https://staging-client.example.com
ALLOW_WILDCARD_CORS=false
PUBLIC_UPLOADS=false
STORAGE_DRIVER=s3
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=unifast-staging
S3_ACCESS_KEY_ID=<STAGING_ONLY>
S3_SECRET_ACCESS_KEY=<STAGING_ONLY>
S3_FORCE_PATH_STYLE=true
VERIFY_STORAGE_ON_START=true
ADMIN_MFA_REQUIRED=true
MFA_DATA_KEY=<64_HEX_CHARACTERS_STAGING_ONLY>
MFA_ISSUER=UNIFAST Ucpavky STAGING
PRIVACY_NOTICE_VERSION=2026-06-27
PRIVACY_NOTICE_URL=https://intranet.example.com/privacy-staging
SECURITY_ALERT_TELEGRAM_BOT_TOKEN=
SECURITY_ALERT_TELEGRAM_CHAT_ID=
LOG_RETENTION_ENABLED=true
LOG_RETENTION_DAYS=90
MESSAGE_RETENTION_DAYS=365
NOTIFICATION_RETENTION_DAYS=180
SENTRY_DSN=
