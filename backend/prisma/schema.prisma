generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  worker
  vedeni
  admin
}

enum MaterialMode {
  with_material
  without_material
}

enum SealStatus {
  draft
  checked
  invoiced
}

enum SealTrade {
  elektrikari
  vzduchari
  vodari
  topenari
  plynari
  ostatni
  neurceno
}

enum WorkSheetStatus {
  draft
  submitted
  reviewed
  ready_for_invoice
  invoiced
  archived
}

enum JobStatus {
  active
  completed
  archived
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  displayName  String    @map("display_name")
  pinHash      String    @map("pin_hash")
  role         UserRole
  materialMode MaterialMode @default(without_material) @map("material_mode")
  isActive     Boolean   @default(true) @map("is_active")
  mustChangePin Boolean  @default(false) @map("must_change_pin")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions     UserSession[]
  createdJobs  Job[]     @relation("JobCreator")
  sealsCreated Seal[]    @relation("SealCreator")
  sealsUpdated Seal[]    @relation("SealUpdater")
  photos       SealPhoto[]
  activityLogs ActivityLog[]
  changeLogs   ChangeLog[]
  loginLogs    LoginLog[]
  jobParticipants JobParticipant[]
  messagesSent    PrivateMessage[] @relation("MessageSender")
  messagesReceived PrivateMessage[] @relation("MessageRecipient")
  worksheetsCreated WorkSheet[] @relation("WorkSheetCreator")
  worksheetAssignments WorkSheetWorker[]
  worksheetItems WorkSheetItem[] @relation("WorkSheetItemWorker")
  notifications Notification[]
  floorDrawingsUploaded FloorDrawing[]
  sealMarkersCreated SealMarker[] @relation("SealMarkerCreator")
  repairsCreated SealRepair[] @relation("SealRepairCreator")

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model Job {
  id            String    @id @default(uuid())
  projectNumber String    @unique @map("project_number") @db.VarChar(8)
  name          String
  address       String?
  note          String?
  status        JobStatus @default(active)
  isArchived    Boolean   @default(false) @map("is_archived")
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  deleteReason  String?   @map("delete_reason")

  createdBy User       @relation("JobCreator", fields: [createdById], references: [id])
  floors    JobFloor[]
  seals     Seal[]
  participants JobParticipant[]
  worksheets WorkSheet[]
  repairs   SealRepair[]

  @@index([status])
  @@map("jobs")
}

model JobFloor {
  id          String    @id @default(uuid())
  jobId       String    @map("job_id")
  name        String
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")
  deleteReason String?  @map("delete_reason")

  job   Job    @relation(fields: [jobId], references: [id])
  seals Seal[]
  worksheetItems WorkSheetItem[]
  drawing FloorDrawing?
  sealMarkers SealMarker[]
  repairs SealRepair[]

  @@index([jobId])
  @@map("job_floors")
}

model Seal {
  id            String     @id @default(uuid())
  jobId         String     @map("job_id")
  floorId       String     @map("floor_id")
  sealNumber    String     @map("seal_number")
  trade         SealTrade  @default(neurceno)
  system        String
  construction  String
  location      String
  fireRating    String     @map("fire_rating")
  note          String?
  internalNote  String?    @map("internal_note")
  openingLengthMm Int?   @map("opening_length_mm")
  openingWidthMm  Int?   @map("opening_width_mm")
  status        SealStatus @default(draft)
  markerPlacementPending Boolean @default(false) @map("marker_placement_pending")
  reviewStatus  String?    @map("review_status")
  reviewComment String?    @map("review_comment")
  version       Int        @default(1)
  createdById   String     @map("created_by_id")
  updatedById   String?    @map("updated_by_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")
  deletedById   String?    @map("deleted_by_id")
  deleteReason  String?    @map("delete_reason")

  job       Job          @relation(fields: [jobId], references: [id])
  floor     JobFloor     @relation(fields: [floorId], references: [id])
  createdBy User         @relation("SealCreator", fields: [createdById], references: [id])
  updatedBy User?        @relation("SealUpdater", fields: [updatedById], references: [id])
  entries   SealEntry[]
  photos    SealPhoto[]
  worksheetItems WorkSheetItem[]
  marker    SealMarker?
  repairs   SealRepair[]

  @@index([floorId])
  @@index([jobId, floorId, sealNumber])
  @@index([createdById])
  @@index([updatedAt])
  @@index([jobId, updatedAt])
  // Partial unique (deleted_at IS NULL): migration 20250528000000_seals_active_number_unique
  @@index([status])
  @@map("seals")
}

model SealEntry {
  id         String    @id @default(uuid())
  sealId     String    @map("seal_id")
  entryType  String    @map("entry_type")
  dimension  String
  quantity   Decimal   @default(1) @db.Decimal(12, 3)
  insulation String
  steelInsulated          Boolean?  @map("steel_insulated")
  electroInstallationType String?   @map("electro_installation_type")
  sortOrder  Int       @default(0) @map("sort_order")
  itemLengthMm           Int?      @map("item_length_mm")
  itemWidthMm            Int?      @map("item_width_mm")
  calculatedAreaM2       Decimal?  @map("calculated_area_m2") @db.Decimal(12, 6)
  calculatedLinearMeters Decimal?  @map("calculated_linear_meters") @db.Decimal(12, 6)
  calculatedNetAreaM2    Decimal?  @map("calculated_net_area_m2") @db.Decimal(12, 6)
  unit                   String?
  unitPrice            Decimal?  @map("unit_price") @db.Decimal(10, 2)
  totalPrice           Decimal?  @map("total_price") @db.Decimal(10, 2)
  currency             String?   @default("CZK")
  priceListVersion     String?   @map("price_list_version")
  priceListItemId      String?   @map("price_list_item_id")
  priceMode            String?   @map("price_mode")
  pricedAt             DateTime? @map("priced_at")
  pricedByUserId       String?   @map("priced_by_user_id")
  priceSource          String?   @map("price_source")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  seal           Seal                 @relation(fields: [sealId], references: [id], onDelete: Cascade)
  materials      SealEntryMaterial[]
  priceListItem  PriceListItem?       @relation(fields: [priceListItemId], references: [id])
  worksheetItems WorkSheetItem[]

  @@index([sealId])
  @@map("seal_entries")
}

model SealEntryMaterial {
  id        String   @id @default(uuid())
  entryId   String   @map("entry_id")
  material  String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  entry SealEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("seal_entry_materials")
}

model SealPhoto {
  id         String   @id @default(uuid())
  sealId     String   @map("seal_id")
  filePath   String   @map("file_path")
  mimeType   String   @map("mime_type")
  fileSize   Int      @map("file_size")
  uploadedById String @map("uploaded_by_id")
  createdAt  DateTime @default(now()) @map("created_at")

  seal       Seal @relation(fields: [sealId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([sealId])
  @@map("seal_photos")
}

model FloorDrawing {
  id           String   @id @default(uuid())
  floorId      String   @unique @map("floor_id")
  filePath     String   @map("file_path")
  mimeType     String   @map("mime_type")
  width        Int
  height       Int
  fileSize     Int      @map("file_size")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  floor      JobFloor @relation(fields: [floorId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@map("floor_drawings")
}

model SealMarker {
  id          String   @id @default(uuid())
  sealId      String   @unique @map("seal_id")
  floorId     String   @map("floor_id")
  x           Float
  y           Float
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  seal      Seal     @relation(fields: [sealId], references: [id], onDelete: Cascade)
  floor     JobFloor @relation(fields: [floorId], references: [id])
  createdBy User     @relation("SealMarkerCreator", fields: [createdById], references: [id])

  @@index([floorId])
  @@index([updatedAt])
  @@map("seal_markers")
}

// Oprava existující ucpávky. Samostatný evidenční záznam navázaný na původní
// ucpávku — vytvoření opravy nikdy nezapisuje do `Seal`. originalSnapshot
// uchovává hodnoty ucpávky v okamžiku opravy (i kdyby se ucpávka později
// změnila), repairData jsou nové hodnoty z formuláře opravy.
model SealRepair {
  id               String   @id @default(uuid())
  sealId           String   @map("seal_id")
  jobId            String   @map("job_id")
  floorId          String   @map("floor_id")
  sealNumber       String   @map("seal_number")
  note             String
  originalSnapshot Json     @map("original_snapshot")
  repairData       Json     @map("repair_data")
  changedFields    Json?    @map("changed_fields")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  seal      Seal     @relation(fields: [sealId], references: [id])
  job       Job      @relation(fields: [jobId], references: [id])
  floor     JobFloor @relation(fields: [floorId], references: [id])
  createdBy User     @relation("SealRepairCreator", fields: [createdById], references: [id])

  @@index([sealId])
  @@index([jobId])
  @@index([createdById])
  @@index([createdAt])
  @@map("seal_repairs")
}

model SyncMutation {
  id          String    @id @default(uuid())
  mutationId  String    @unique @map("mutation_id")
  deviceId    String    @map("device_id")
  userId      String    @map("user_id")
  entityType  String    @map("entity_type")
  operation   String
  payload     Json
  result      Json?
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("sync_mutations")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("activity_log")
}

model ChangeLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  fieldName  String?  @map("field_name")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("change_log")
}

model WorkSheet {
  id                 String           @id @default(uuid())
  jobId              String           @map("job_id")
  status             WorkSheetStatus  @default(draft)
  // "worker" (s cenami) nebo "customer" (bez cen v exportu i v appce).
  audience           String           @default("worker")
  periodFrom         DateTime?        @map("period_from")
  periodTo           DateTime?        @map("period_to")
  note               String?
  internalNote       String?          @map("internal_note")
  createdById        String           @map("created_by_id")
  submittedAt        DateTime?        @map("submitted_at")
  reviewedAt         DateTime?        @map("reviewed_at")
  readyForInvoiceAt  DateTime?        @map("ready_for_invoice_at")
  invoicedAt         DateTime?        @map("invoiced_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  job      Job               @relation(fields: [jobId], references: [id])
  createdBy User             @relation("WorkSheetCreator", fields: [createdById], references: [id])
  workers  WorkSheetWorker[]
  items    WorkSheetItem[]

  @@index([jobId])
  @@index([status])
  @@map("worksheets")
}

model WorkSheetWorker {
  id          String   @id @default(uuid())
  worksheetId String   @map("worksheet_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  worksheet WorkSheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([worksheetId, userId])
  @@map("worksheet_workers")
}

model WorkSheetItem {
  id           String   @id @default(uuid())
  worksheetId  String   @map("worksheet_id")
  sealId       String   @map("seal_id")
  sealEntryId  String   @map("seal_entry_id")
  floorId      String   @map("floor_id")
  workerId     String   @map("worker_id")
  sealNumber   String   @map("seal_number")
  trade        SealTrade @default(neurceno)
  entryType    String   @map("entry_type")
  dimension    String
  quantity     Decimal  @default(1) @db.Decimal(12, 3)
  unit         String?  @default("kus")
  // Snapshot technických/popisných údajů ucpávky v okamžiku vytvoření soupisu (Task 7/9).
  system       String?
  insulation   String?
  location     String?
  catalogId    String?  @map("catalog_id")
  unitPrice    Decimal? @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal? @map("total_price") @db.Decimal(10, 2)
  priceListVersion String? @map("price_list_version")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  worksheet WorkSheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  seal      Seal      @relation(fields: [sealId], references: [id])
  sealEntry SealEntry @relation(fields: [sealEntryId], references: [id])
  floor     JobFloor  @relation(fields: [floorId], references: [id])
  worker    User      @relation("WorkSheetItemWorker", fields: [workerId], references: [id])

  @@unique([worksheetId, sealEntryId])
  @@unique([sealEntryId])
  @@index([worksheetId])
  @@map("worksheet_items")
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  username  String?
  success   Boolean
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("login_log")
}

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  stack     String?
  path      String?
  method    String?
  userId    String?  @map("user_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("error_log")
}

model JobParticipant {
  id             String   @id @default(uuid())
  jobId          String   @map("job_id")
  userId         String   @map("user_id")
  roleOnJob      String   @map("role_on_job")
  assignedById   String?  @map("assigned_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId])
  @@map("job_participants")
}

model PrivateMessage {
  id          String    @id @default(uuid())
  senderId    String    @map("sender_id")
  recipientId String    @map("recipient_id")
  body        String
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  sender    User @relation("MessageSender", fields: [senderId], references: [id])
  recipient User @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([recipientId, readAt])
  @@map("private_messages")
}

model PriceList {
  id        String    @id @default(uuid())
  version   String    @unique
  validFrom DateTime  @map("valid_from")
  validTo   DateTime? @map("valid_to")
  active    Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  items PriceListItem[]

  @@map("price_lists")
}

model PriceListItem {
  id                   String   @id @default(uuid())
  priceListId          String   @map("price_list_id")
  category             String
  sizeLabel            String   @map("size_label")
  unit                 String   @default("kus")
  priceWithMaterial    Decimal  @map("price_with_material") @db.Decimal(10, 2)
  priceWithoutMaterial Decimal? @map("price_without_material") @db.Decimal(10, 2)
  active               Boolean  @default(true)
  sortOrder            Int      @default(0) @map("sort_order")

  priceList   PriceList   @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  sealEntries SealEntry[]

  @@index([priceListId, category])
  @@map("price_list_items")
}

model Notification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       String
  title      String
  body       String
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model BackupLog {
  id           String   @id @default(uuid())
  fileName     String   @map("file_name")
  filePath     String   @map("file_path")
  fileSizeBytes BigInt? @map("file_size_bytes")
  status       String
  errorMessage String?  @map("error_message")
  triggeredBy  String?  @map("triggered_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("backup_logs")
}
