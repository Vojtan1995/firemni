# Produkční env proměnné pro Railway
# Zkopírovat hodnoty do Railway dashboard → Variables
# Nikdy necommitovat tento soubor s reálnými hodnotami

# ── Databáze ─────────────────────────────────────────────────────────────────
# Railway PostgreSQL addon nastavuje automaticky
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Autentizace ───────────────────────────────────────────────────────────────
# Minimálně 32 náhodných znaků — vygenerovat: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_32_CHARS_MINIMUM

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT nastavuje Railway automaticky — NEUVÁDĚT ručně

# ── CORS ─────────────────────────────────────────────────────────────────────
# Nastavit na HTTPS origin Flutter klientů nebo ponechat * + ALLOW_WILDCARD_CORS=true
# Pro produkci doporučeno: explicitní origin nebo wildcard s vědomým souhlasem
CORS_ORIGIN=https://app.example.com
ALLOW_WILDCARD_CORS=false

# ── Fotky / Storage ───────────────────────────────────────────────────────────
# Volba: 'local' (ephemeral, nevhodné pro Railway) nebo 's3' (doporučeno)
STORAGE_DRIVER=s3
PUBLIC_UPLOADS=false

# Cloudflare R2 (doporučeno — bez egress poplatků):
# Lokalni helper skripty umi z R2_ACCOUNT_ID slozit S3_ENDPOINT. Do Railway nastavujte S3_ENDPOINT.
# R2_ACCOUNT_ID=ACCOUNT_ID
S3_BUCKET=ucpavky-photos
S3_ACCESS_KEY_ID=CLOUDFLARE_R2_ACCESS_KEY
S3_SECRET_ACCESS_KEY=CLOUDFLARE_R2_SECRET_KEY
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_FORCE_PATH_STYLE=true
S3_REGION=auto
S3_KEY_PREFIX=photos
VERIFY_STORAGE_ON_START=true

# AWS S3 alternativa:
# S3_BUCKET=ucpavky-photos
# S3_ACCESS_KEY_ID=AWS_ACCESS_KEY
# S3_SECRET_ACCESS_KEY=AWS_SECRET_KEY
# S3_REGION=eu-central-1
# S3_FORCE_PATH_STYLE=false

# ── Sentry (error tracking) ───────────────────────────────────────────────────
SENTRY_DSN=https://XXXX@XXXX.ingest.sentry.io/XXXX

# ── Android app release (update checker) ─────────────────────────────────────
# Po nahrání APK na HTTPS (např. GitHub Release asset) nastavit build číslo
# (= +N v pubspec.yaml). MIN_BUILD = nejnižší ještě podporovaný build; nastav
# ho rovno BUILD pro VYNUCENOU aktualizaci (klient nepustí dál bez updatu).
# APP_RELEASE_VERSION_NAME=1.1.0
# APP_RELEASE_BUILD=2
# APP_RELEASE_MIN_BUILD=1
# APP_RELEASE_APK_URL=https://github.com/<org>/<repo>/releases/download/v1.1.0/ucpavky-1.1.0.apk
# APP_RELEASE_NOTES=Opravy offline výkresu

# ── Windows app release (update checker) ─────────────────────────────────────
# URL ukazuje na instalátor (.exe z Inno Setup) nebo Release.zip na HTTPS.
# Build je nezávislý na Androidu — drž ho v sync s pubspec.yaml (+N).
# APP_RELEASE_WIN_VERSION_NAME=1.1.0
# APP_RELEASE_WIN_BUILD=2
# APP_RELEASE_WIN_MIN_BUILD=1
# APP_RELEASE_WIN_URL=https://github.com/<org>/<repo>/releases/download/v1.1.0/ucpavky-setup-1.1.0.exe
# APP_RELEASE_WIN_NOTES=Opravy offline výkresu

# ── Zálohy (vestavěný scheduler — volitelné, doporučeno GitHub Actions) ───────
# Pokud chceš zapnout interní scheduler (ukládá na Railway disk — ephemeral):
# BACKUP_ENABLED=false
# BACKUP_DIR=./backups
# BACKUP_RETENTION_COUNT=7
# BACKUP_INTERVAL_HOURS=24
# BACKUP_REPORT_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
# ALLOW_LOCAL_BACKUP_IN_PRODUCTION=false

# ── Retence logů (GDPR data minimization) ────────────────────────────────────
# Maže staré login logy (IP/user agent), error logy a zpracované sync mutace.
# Běží nezávisle na zálohách; v produkci je zapnuté ve výchozím stavu.
# LOG_RETENTION_ENABLED=true
# LOG_RETENTION_DAYS=90
# LOG_RETENTION_INTERVAL_HOURS=24
# MESSAGE_RETENTION_DAYS=365
# NOTIFICATION_RETENTION_DAYS=180

# ── Admin MFA ────────────────────────────────────────────────────────────────
# Produkce fail-closed: pro live provoz musi byt MFA povinne.
# Docasne false patri jen do bootstrap kroku pred verejnym provozem, kdy se
# enrolluji alespon dva admini podle docs/P0_ROLLOUT_RUNBOOK.md.
ADMIN_MFA_REQUIRED=true
MFA_DATA_KEY=<64_HEX_CHARACTERS>
MFA_ISSUER=UNIFAST Ucpavky
PRIVACY_NOTICE_VERSION=2026-06-27
PRIVACY_NOTICE_URL=https://intranet.example.com/privacy
SECURITY_ALERT_TELEGRAM_BOT_TOKEN=
SECURITY_ALERT_TELEGRAM_CHAT_ID=
